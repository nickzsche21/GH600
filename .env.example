SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_ONLY_SERVICE_ROLE_KEY

# Legacy Razorpay fallback links (kept for back-compat; Paddle is primary — see below)
RAZORPAY_FOUNDING_URL=
RAZORPAY_TEAM_URL=
RAZORPAY_CRAM_URL=

# Server-side signing/auth secrets — never exposed to the client
ENTITLEMENT_SIGNING_SECRET=YOUR_RANDOM_32_BYTE_HEX_SECRET
ADMIN_API_TOKEN=YOUR_RANDOM_ADMIN_TOKEN

# Paddle (Merchant of Record; automated card checkout via hosted payment links)
# — currently stuck in merchant verification; Gumroad below is the interim
# provider, but these stay set so flipping back is a one-line env change.
PADDLE_WEBHOOK_SECRET=YOUR_PADDLE_WEBHOOK_SECRET
PADDLE_API_KEY=YOUR_PADDLE_API_KEY
PADDLE_ENV=sandbox
PADDLE_PRICE_FOUNDING=pri_YOUR_FOUNDING_PRICE_ID
PADDLE_PRICE_TEAM=pri_YOUR_TEAM_PRICE_ID
PADDLE_PRICE_CRAM=pri_YOUR_CRAM_PRICE_ID
PADDLE_PRICE_PRO=pri_YOUR_PRO_PRICE_ID
PADDLE_CHECKOUT_FOUNDING=https://YOUR_DOMAIN.paddle.io/checkout/YOUR_FOUNDING_LINK
PADDLE_CHECKOUT_TEAM=https://YOUR_DOMAIN.paddle.io/checkout/YOUR_TEAM_LINK
PADDLE_CHECKOUT_CRAM=https://YOUR_DOMAIN.paddle.io/checkout/YOUR_CRAM_LINK
PADDLE_CHECKOUT_PRO=https://YOUR_DOMAIN.paddle.io/checkout/YOUR_PRO_LINK

# Gumroad (interim Merchant of Record while Paddle is in verification).
# Access token is server-only — never reference it, log it, or let it reach
# index.html/app.js/*-config.js.
GUMROAD_ACCESS_TOKEN=YOUR_GUMROAD_ACCESS_TOKEN
GUMROAD_PRODUCT_FOUNDING=YOUR_GUMROAD_FOUNDING_PRODUCT_ID
GUMROAD_PRODUCT_PRO=YOUR_GUMROAD_PRO_PRODUCT_ID
GUMROAD_CHECKOUT_FOUNDING=https://nikhilite46.gumroad.com/l/ewvqwg
GUMROAD_CHECKOUT_PRO=https://nikhilite46.gumroad.com/l/fbylmr
